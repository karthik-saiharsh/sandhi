# ============================================================
# Frontend .gitignore  (React + Vite + TypeScript)
# ============================================================

# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Build output ─────────────────────────────────────────────
dist/
dist-ssr/
build/
.vite/

# ── Environment / Secrets ────────────────────────────────────
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Test / Coverage ─────────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/

# ── OS / Editor ─────────────────────────────────────────────
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.idea/
.vscode/*
!.vscode/extensions.json

# ── TypeScript ──────────────────────────────────────────────
*.tsbuildinfo

# ── Misc ────────────────────────────────────────────────────
*.local
