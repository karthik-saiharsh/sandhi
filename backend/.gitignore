# ============================================================
# Backend .gitignore  (FastAPI / Python)
# ============================================================

# ── Virtual environments ────────────────────────────────────
.venv/
venv/
env/

# ── Python cache ────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/

# ── Build / dist ────────────────────────────────────────────
dist/
build/
*.whl

# ── Environment / Secrets ────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── Logs ────────────────────────────────────────────────────
*.log
logs/

# ── Upload / temp files ─────────────────────────────────────
uploads/
tmp/

# ── Test artefacts ──────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
